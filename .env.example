# ══════════════════════════════════════════════════════════════
# BibelôCRM — Variáveis de ambiente (TEMPLATE)
# Ecossistema Bibelô — Papelaria
# Copie para .env e preencha. NUNCA commite o .env real.
# ══════════════════════════════════════════════════════════════

NODE_ENV=production
APP_NAME=BibelôCRM
APP_URL=https://crm.papelariabibelo.com.br
API_PORT=4000
FRONTEND_PORT=3000

DB_HOST=postgres
DB_PORT=5432
DB_NAME=bibelocrm
DB_USER=bibelocrm
DB_PASS=SUA_SENHA_FORTE_AQUI
DATABASE_URL=postgresql://bibelocrm:SUA_SENHA@postgres:5432/bibelocrm

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=SUA_SENHA_REDIS
REDIS_URL=redis://:SUA_SENHA_REDIS@redis:6379

JWT_SECRET=MINIMO_32_CHARS_ALEATORIOS
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

NUVEMSHOP_APP_ID=SEU_APP_ID
NUVEMSHOP_CLIENT_SECRET=SEU_CLIENT_SECRET
NUVEMSHOP_REDIRECT_URI=https://crm.papelariabibelo.com.br/api/auth/nuvemshop/callback
NUVEMSHOP_WEBHOOK_SECRET=SEU_CLIENT_SECRET

BLING_CLIENT_ID=SEU_CLIENT_ID
BLING_CLIENT_SECRET=SEU_CLIENT_SECRET
BLING_REDIRECT_URI=https://crm.papelariabibelo.com.br/api/auth/bling/callback

RESEND_API_KEY=re_XXXXXXXXXXXXXXXX
EMAIL_FROM=noreply@papelariabibelo.com.br
EMAIL_REPLY_TO=contato@papelariabibelo.com.br

EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=GERE_CHAVE_FORTE
EVOLUTION_INSTANCE=bibelocrm
EVOLUTION_CLUBE_VIP_GROUP_JID=   # preencher após conectar o WhatsApp (ex: 120363...@g.us)

# WAHA — WhatsApp HTTP API (read-only, verificação grupo VIP)
WAHA_URL=http://waha:3000
WAHA_API_KEY=GERE_CHAVE_FORTE_WAHA
WAHA_SESSION=bibelo
WAHA_GRUPO_VIP_JID=   # preencher após conectar: GET /api/bibelo/groups → copiar o id do grupo VIP
WAHA_DASHBOARD_USER=carlos
WAHA_DASHBOARD_PASS=GERE_SENHA_FORTE

BACKUP_DIR=/opt/bibelocrm/backups
R2_BUCKET=bibelocrm-backups
R2_ACCOUNT_ID=SEU_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY=SEU_R2_ACCESS_KEY
R2_SECRET_KEY=SEU_R2_SECRET_KEY

INTERNAL_NOTIFY_KEY=CHAVE_PARA_NOTIF_DEPLOY

# ── Google OAuth2
GOOGLE_CLIENT_ID=SEU_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=SEU_GOOGLE_CLIENT_SECRET

# ── Meta Ads (Facebook + Instagram)
META_ACCESS_TOKEN=SEU_TOKEN_META_AQUI
META_AD_ACCOUNT_ID=SEU_AD_ACCOUNT_ID

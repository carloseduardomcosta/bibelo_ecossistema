{
  "name": "bibelocrm-api",
  "version": "1.0.0",
  "description": "BibelôCRM — API Backend — Ecossistema Bibelô",
  "main": "dist/server.js",
  "scripts": {
    "dev":        "tsx watch src/server.ts",
    "build":      "tsc --project tsconfig.json",
    "start":      "node dist/server.js",
    "db:migrate": "node dist/db/migrate.js",
    "lint":       "eslint src --ext .ts"
  },
  "dependencies": {
    "express":          "^4.18.2",
    "express-async-errors": "^3.1.1",
    "cors":             "^2.8.5",
    "helmet":           "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "pg":               "^8.11.3",
    "redis":            "^4.6.12",
    "bullmq":           "^5.1.1",
    "jsonwebtoken":     "^9.0.2",
    "bcryptjs":         "^2.4.3",
    "zod":              "^3.22.4",
    "resend":           "^2.1.0",
    "axios":            "^1.6.5",
    "dotenv":           "^16.3.1",
    "winston":          "^3.11.0",
    "date-fns":         "^3.2.0",
    "date-fns-tz":      "^2.0.0"
  },
  "devDependencies": {
    "@types/express":       "^4.17.21",
    "@types/cors":          "^2.8.17",
    "@types/pg":            "^8.10.9",
    "@types/jsonwebtoken":  "^9.0.5",
    "@types/bcryptjs":      "^2.4.6",
    "@types/node":          "^20.11.5",
    "typescript":           "^5.3.3",
    "tsx":                  "^4.7.0"
  }
}
